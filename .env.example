# Store Intelligence Configuration Example
# Copy this file to .env and configure as needed

# Database configuration
POSTGRES_USER=store_admin
POSTGRES_PASSWORD=SUPER_SECRET_PASSWORD_HERE
POSTGRES_DB=storedb
# Used when running natively (outside docker)
# DATABASE_URL=postgresql+asyncpg://store_admin:SUPER_SECRET_PASSWORD_HERE@localhost:5432/storedb
# Used when running inside docker-compose
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# API Service
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=info

# Data Paths
STORE_LAYOUT_PATH=data/store_layout.json
POS_CSV_PATH=data/pos_transactions.csv
EVENTS_OUTPUT_DIR=data/events

# Pipeline thresholds
REID_THRESHOLD=0.6
STAFF_CONFIDENCE_THRESHOLD=0.85

# Analytics Configuration
ZONE_DWELL_SECONDS=30
QUEUE_DWELL_SECONDS=5
